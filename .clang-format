# Project C++ formatting target.
#
# This file defines the mechanical whitespace/line-wrapping rules for new code
# and for future format-only cleanup commits. Some existing files may not yet
# match it exactly.
#
# Baseline: Google C++ style.
# Project changes:
#   - ColumnLimit is relaxed from Google's default 80 to 100.
#   - AccessModifierOffset is changed from Google's default -1 to -2 so
#     public/private/protected labels start at column 0.
# Naming and semantic style rules live in .claude/rules/coding-style.md.
BasedOnStyle: Google
ColumnLimit: 100
AccessModifierOffset: -2
